@using Microsoft.AspNetCore.Components.Web

<ErrorBoundary @ref="errorBoundary">
    <ChildContent>
        @ChildContent
    </ChildContent>
    <ErrorContent Context="exception">
        @{
            LogError(exception);
        }
        <div class="error-boundary-container" role="alert">
            <h4 class="error-boundary-heading">Error</h4>
            <p class="error-boundary-message">Ha ocurrido un error inesperado en la aplicación.</p>

            @if (ShowDetails)
            {
                <hr class="error-boundary-divider">
                <details class="error-boundary-details">
                    <summary>Información técnica</summary>
                    <pre>@exception.ToString()</pre>
                </details>
            }

            <hr class="error-boundary-divider">
            <button class="error-boundary-button" @onclick="Recover">
                Intentar recuperar
            </button>
            <button class="error-boundary-button error-boundary-button-secondary" @onclick="ReloadPage">
                Recargar página
            </button>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Inject]
    private IWebHostEnvironment Environment { get; set; } = default!;

    [Inject]
    private ILogger<GlobalErrorBoundary> Logger { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private ErrorBoundary? errorBoundary;
    private bool ShowDetails => Environment.IsDevelopment();

    protected override void OnParametersSet()
    {
        errorBoundary?.Recover();
    }

    private void LogError(Exception exception)
    {
        Logger.LogError(exception,
            "Error capturado por ErrorBoundary en: {Url}",
            Navigation.Uri);
    }

    private void Recover()
    {
        errorBoundary?.Recover();
    }

    private void ReloadPage()
    {
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}
